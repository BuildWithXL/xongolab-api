# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=no-reply@yourdomain.com
FROM_NAME=Xongolab

# Admin / HR recipient
ADMIN_EMAIL=admin@yourdomain.com
